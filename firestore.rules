rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    /**
     * Check if user is authenticated
     */
    function isAuthenticated() {
      return request.auth != null;
    }

    /**
     * Check if user is in allowlist and enabled
     * Checks both by UID (primary) and email (fallback)
     */
    function isAllowed() {
      return isAuthenticated() && (
        // Check by UID (primary method)
        exists(/databases/$(database)/documents/allowedUsers/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/allowedUsers/$(request.auth.uid)).data.enabled == true
      ) || (
        // Fallback: Check by email
        exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)).data.enabled == true
      );
    }

    /**
     * Check if user owns the resource
     */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ==================== ALLOWED USERS COLLECTION ====================

    /**
     * allowedUsers collection
     * - Only allowed users can read their own document
     * - No write access (managed by admin only)
     */
    match /allowedUsers/{userId} {
      // Allow users to read their own allowlist entry
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        request.auth.token.email == resource.data.email
      );

      // No write access - only admin can manage this via Firebase Console
      allow write: if false;
    }

    // ==================== CURATED EXERCISES COLLECTION ====================

    /**
     * exercises_curated collection
     * - Read-only for allowed users (system exercises)
     * - Write access only via Admin SDK (import script)
     */
    match /exercises_curated/{exerciseId} {
      allow read: if isAllowed();
      allow write: if false;
    }

    // ==================== EXERCISES COLLECTION ====================

    /**
     * exercises collection (user-created exercises)
     * - Each user can only access their own exercises
     * - userId is required and must match the authenticated user
     */
    match /exercises/{exerciseId} {
      allow read: if isAllowed() && isOwner(resource.data.userId);
      allow create: if isAllowed() &&
        isOwner(request.resource.data.userId) &&
        request.resource.data.keys().hasAll(['name', 'muscleGroups', 'difficulty', 'userId']) &&
        request.resource.data.name is string &&
        request.resource.data.muscleGroups is list &&
        request.resource.data.difficulty is number;
      allow update: if isAllowed() &&
        isOwner(resource.data.userId) &&
        isOwner(request.resource.data.userId);
      allow delete: if isAllowed() && isOwner(resource.data.userId);
    }

    // ==================== PLANS COLLECTION ====================

    /**
     * plans collection
     * - Each user can only access their own plans
     * - userId is required and must match the authenticated user
     */
    match /plans/{planId} {
      allow read: if isAllowed() && isOwner(resource.data.userId);
      allow create: if isAllowed() &&
        isOwner(request.resource.data.userId) &&
        request.resource.data.keys().hasAll(['name', 'userId']);
      allow update: if isAllowed() &&
        isOwner(resource.data.userId) &&
        isOwner(request.resource.data.userId);
      allow delete: if isAllowed() && isOwner(resource.data.userId);
    }

    // ==================== SESSIONS COLLECTION ====================

    /**
     * sessions collection
     * - Each user can only access their own sessions
     * - userId is required and must match the authenticated user
     */
    match /sessions/{sessionId} {
      allow read: if isAllowed() && isOwner(resource.data.userId);
      allow create: if isAllowed() &&
        isOwner(request.resource.data.userId) &&
        request.resource.data.keys().hasAll(['type', 'userId']);
      allow update: if isAllowed() &&
        isOwner(resource.data.userId) &&
        isOwner(request.resource.data.userId);
      allow delete: if isAllowed() && isOwner(resource.data.userId);
    }

    // ==================== PROGRESS COLLECTION ====================

    /**
     * progress collection
     * - Each user can only access their own progress entries
     * - userId is required and must match the authenticated user
     */
    match /progress/{progressId} {
      allow read: if isAllowed() && isOwner(resource.data.userId);
      allow create: if isAllowed() &&
        isOwner(request.resource.data.userId) &&
        request.resource.data.keys().hasAll(['exerciseId', 'userId']);
      allow update: if isAllowed() &&
        isOwner(resource.data.userId) &&
        isOwner(request.resource.data.userId);
      allow delete: if isAllowed() && isOwner(resource.data.userId);
    }

    // ==================== WORKOUTS COLLECTION ====================

    /**
     * workouts collection (currently unused, kept for future use)
     */
    match /workouts/{workoutId} {
      allow read: if isAllowed();
      allow create: if isAllowed() &&
        request.resource.data.keys().hasAll(['planId', 'date', 'status']) &&
        request.resource.data.planId is string &&
        request.resource.data.date is timestamp &&
        request.resource.data.status is string;
      allow update: if isAllowed();
      allow delete: if isAllowed();
    }

    // ==================== SCHEDULE COLLECTION ====================

    /**
     * schedule collection
     * - Each user can only access their own schedule entries
     * - userId is required and must match the authenticated user
     */
    match /schedule/{scheduleId} {
      allow read: if isAllowed() && isOwner(resource.data.userId);
      allow create: if isAllowed() &&
        isOwner(request.resource.data.userId) &&
        request.resource.data.keys().hasAll(['date', 'userId']);
      allow update: if isAllowed() &&
        isOwner(resource.data.userId) &&
        isOwner(request.resource.data.userId);
      allow delete: if isAllowed() && isOwner(resource.data.userId);
    }

    // ==================== SESSION TEMPLATES COLLECTION ====================

    /**
     * sessionTemplates collection
     * - Each user can only access their own session templates
     * - userId is required and must match the authenticated user
     */
    match /sessionTemplates/{templateId} {
      allow read: if isAllowed() && isOwner(resource.data.userId);
      allow create: if isAllowed() &&
        isOwner(request.resource.data.userId);
      allow update: if isAllowed() &&
        isOwner(resource.data.userId) &&
        isOwner(request.resource.data.userId);
      allow delete: if isAllowed() && isOwner(resource.data.userId);
    }

    // ==================== USER PROFILES COLLECTION ====================

    /**
     * userProfiles collection
     * - Users can only read/write their own profile document
     * - Document ID must match the authenticated user's UID
     */
    match /userProfiles/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // ==================== DEFAULT DENY ====================

    /**
     * Deny all other requests by default
     */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
