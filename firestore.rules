rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    /**
     * Check if user is authenticated
     */
    function isAuthenticated() {
      return request.auth != null;
    }

    /**
     * Check if user is in allowlist and enabled
     * Checks both by UID (primary) and email (fallback)
     */
    function isAllowed() {
      return isAuthenticated() && (
        // Check by UID (primary method)
        exists(/databases/$(database)/documents/allowedUsers/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/allowedUsers/$(request.auth.uid)).data.enabled == true
      ) || (
        // Fallback: Check by email
        exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)).data.enabled == true
      );
    }

    /**
     * Check if user owns the resource
     */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ==================== ALLOWED USERS COLLECTION ====================

    /**
     * allowedUsers collection
     * - Only allowed users can read their own document
     * - No write access (managed by admin only)
     */
    match /allowedUsers/{userId} {
      // Allow users to read their own allowlist entry
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        request.auth.token.email == resource.data.email
      );

      // No write access - only admin can manage this via Firebase Console
      allow write: if false;
    }

    // ==================== EXERCISES COLLECTION ====================

    /**
     * exercises collection
     * - Allowed users can read, create, update, delete exercises
     * - All exercises are shared across all allowed users
     */
    match /exercises/{exerciseId} {
      allow read: if isAllowed();
      allow create: if isAllowed() &&
        request.resource.data.keys().hasAll(['name', 'muscleGroups', 'difficulty']) &&
        request.resource.data.name is string &&
        request.resource.data.muscleGroups is list &&
        request.resource.data.difficulty is number;
      allow update: if isAllowed() &&
        request.resource.data.keys().hasAll(['name', 'muscleGroups', 'difficulty']);
      allow delete: if isAllowed();
    }

    // ==================== PLANS COLLECTION ====================

    /**
     * plans collection
     * - Allowed users can read, create, update, delete plans
     * - All plans are shared across all allowed users
     */
    match /plans/{planId} {
      allow read: if isAllowed();
      allow create: if isAllowed() &&
        request.resource.data.keys().hasAll(['name', 'exercises']) &&
        request.resource.data.name is string &&
        request.resource.data.exercises is list;
      allow update: if isAllowed();
      allow delete: if isAllowed();
    }

    // ==================== WORKOUTS COLLECTION ====================

    /**
     * workouts collection
     * - Allowed users can read, create, update, delete workouts
     * - All workouts are shared across all allowed users
     */
    match /workouts/{workoutId} {
      allow read: if isAllowed();
      allow create: if isAllowed() &&
        request.resource.data.keys().hasAll(['planId', 'date', 'status']) &&
        request.resource.data.planId is string &&
        request.resource.data.date is timestamp &&
        request.resource.data.status is string;
      allow update: if isAllowed();
      allow delete: if isAllowed();
    }

    // ==================== SCHEDULE COLLECTION ====================

    /**
     * schedule collection
     * - Allowed users can read, create, update, delete schedule entries
     * - All schedule entries are shared across all allowed users
     */
    match /schedule/{scheduleId} {
      allow read: if isAllowed();
      allow create: if isAllowed() &&
        request.resource.data.keys().hasAll(['date', 'planId']) &&
        request.resource.data.date is string &&
        request.resource.data.planId is string;
      allow update: if isAllowed();
      allow delete: if isAllowed();
    }

    // ==================== DEFAULT DENY ====================

    /**
     * Deny all other requests by default
     */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
